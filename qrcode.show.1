.SS SHELL FUNCTIONS
Shell functions that can be added to \f[CR].bashrc\f[R] or
\f[CR].bash_profle\f[R] for quickly generating QR codes from the command
line.
The command takes the argument as input or reads from stdin if none was
supplied and outputs the QR code to stdout.
.IP
.EX
qrcode () \f[B]{\f[R]
    local input=\(dq$*\(dq
    [ \-z \(dq$input\(dq ] \f[B]&&\f[R] local input=\(dq\(at/dev/stdin\(dq
    curl \-d \(dq$input\(dq https://qrcode.show
\f[B]}\f[R]
qrsvg () \f[B]{\f[R]
    local input=\(dq$*\(dq
    [ \-z \(dq$input\(dq ] \f[B]&&\f[R] local input=\(dq\(at/dev/stdin\(dq
    curl \-d \(dq${input}\(dq https://qrcode.show \-H \(dqAccept: image/svg+xml\(dq
\f[B]}\f[R]
qrserve () \f[B]{\f[R]
    local port=${1:\-8080}
    local dir=${2:\-.}
    local ip=\(dq$(ifconfig \f[B]|\f[R] grep \-Eo \(aq[0\-9]{1,3}\(rs.[0\-9]{1,3}\(rs.[0\-9]{1,3}\(rs.[0\-9]{1,3}\(aq \f[B]|\f[R] fzf \-\-prompt IP:)\(dq \(rs
    \f[B]&&\f[R] echo http://$ip:$port \f[B]|\f[R] qrcode \(rs
    \f[B]&&\f[R] python \-m http.server $port \-b $ip \-d $dir
\f[B]}\f[R]
.EE
